# Discord
DISCORD_TOKEN=your_bot_token_here
# Comma-separated Discord user IDs with full admin rights
DISCORD_ADMIN_IDS=123456789012345678,987654321098765432
# Comma-separated Discord user IDs — bu kullanıcılar sunucuda slash komutlarını kullanamaz (isteğe bağlı)
# DISCORD_BANNED_IDS=
# Optional: restrict slash commands to a guild for faster sync during dev
# DISCORD_GUILD_ID=

# Database: sqlite (default) or postgresql
# SQLite (file path relative to cwd or absolute)
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/gnubot

# Roblox follow checker
FOLLOW_CHECK_INTERVAL_SECONDS=120
ROBLOX_HTTP_TIMEOUT_SECONDS=25
ROBLOX_MAX_RETRIES=4
ROBLOX_CACHE_TTL_SECONDS=45

# Points
FOLLOW_REWARD_POINTS=5
FOLLOW_PENALTY_POINTS=5

# Rate limits (per Discord user, sliding window seconds)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_COMMANDS=15

# Command cooldowns (seconds)
COOLDOWN_REGISTER_SECONDS=30
COOLDOWN_TASKS_SECONDS=10
COOLDOWN_LEADERBOARD_SECONDS=15
# Takip doğrulama / kredi talebi (/check)
COOLDOWN_CHECK_SECONDS=25
COOLDOWN_REDEMPTION_SECONDS=120
COOLDOWN_TALEPLERIM_SECONDS=12

# Nakit talebi limitleri (0 = tek talepte üst sınır yok, sadece bakiye)
MAX_SINGLE_REDEMPTION=50000
MAX_PENDING_REDEMPTIONS_PER_USER=2

# Legacy prefix (optional admin / music)
BOT_COMMAND_PREFIX=$

# Music: optional ffmpeg path (Windows example)
# FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe

# Logging
LOG_LEVEL=INFO
